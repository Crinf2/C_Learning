# --- 白名单模式开始 ---

# 1. 忽略根目录下的所有文件
*

# 2. 但不要忽略 .gitignore 本身（否则配置会失效）
!.gitignore

# 3. 允许上传根目录的 README 说明文件（可选，方便你在首页写介绍）
!README.md

# 4. 允许进入 code 文件夹（否则里面的文件也进不去）
!/code/

# 5. 在 code 文件夹内，默认也忽略所有
/code/*

# 6. 但允许 code 下的子文件夹（你的每日学习文件夹）
!/code/*/
!/code/*/*/

# 7. 【关键】只放行特定后缀的源代码文件
# 这样 .exe, .o, .obj, .log, .tmp 等垃圾文件自动被过滤
!/code/**/*.c
!/code/**/*.h
!/code/**/*.cpp
!/code/**/*.hpp

# 8. 允许代码文件夹内的说明文档（如每日笔记）
!/code/**/*.md
!/code/**/*.txt

# --- 白名单模式结束 ---
